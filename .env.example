# Google & Bing Configuration
BING_API_KEY=your_bing_api_key_here

# Target Domain settings
# SITE_URL should be exactly how it appears in Google Search Console (e.g. sc-domain:example.com or https://example.com/)
GSC_SITE_URL=sc-domain:yourdomain.com
SITE_LAUNCH_DATE=2024-01-01

# GA4 Settings
# List of GA4 Property IDs and their corresponding labels (comma separated)
# Example: 123456789=yourdomain.com,987654321=otherdomain.com
GA4_PROPERTIES=123456789=yourdomain.com

# Target URL for Bing queries (typically your homepage url)
BING_SITE_URL=https://yourdomain.com
